  "variable": [
    {
      "key": "BASE_URL",
      "value": "http://localhost:5000/api/v1",
      "type": "string"
    },
    {
      "key": "ACCESS_TOKEN",
      "value": "aldjDSFAD",
      "type": "string"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{ACCESS_TOKEN}}",
        "type": "string"
      }
    ]
  },
